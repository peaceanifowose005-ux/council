import { GoogleGenAI } from "@google/generative-ai";
import { NextResponse } from "next/server";

// Initialize the Gemini API with the environment variable we set in Vercel
const apiKey = process.env.GEMINI_API_KEY || "";
const ai = new GoogleGenAI({ apiKey });

export async function POST(req: Request) {
  try {
    const { question } = await req.json();

    if (!question) {
      return NextResponse.json({ error: "Question is required" }, { status: 400 });
    }

    // Define your Board of Directors profiles
    const boardMembers = [
      {
        name: "Visionary Strategist",
        prompt: "You are a long-term strategic growth expert. Analyze this dilemma focusing on scaling, sustainability, and future opportunities: "
      },
      {
        name: "Risk Analyst & Legal Mind",
        prompt: "You are a conservative risk manager and legal advisor. Analyze this dilemma focusing on potential pitfalls, hidden liabilities, and security vulnerabilities: "
      },
      {
        name: "Creative Innovator",
        prompt: "You are a disruptive, out-of-the-box creative thinker. Analyze this dilemma focusing on unconventional solutions, marketing angles, and unique branding opportunities: "
      }
    ];

    // Request responses from Gemini for each board member simultaneously
    const responsePromises = boardMembers.map(async (member) => {
      try {
        const model = ai.getGenerativeModel({ model: "gemini-1.5-flash" });
        const result = await model.generateContent(`${member.prompt}\n\nUser Dilemma: "${question}"`);
        const text = result.response.text();
        
        return {
          name: member.name,
          answer: text.trim(),
        };
      } catch (error) {
        return {
          name: member.name,
          answer: "Failed to deliberate. Check API key or connection.",
        };
      }
    });

    const boardResponses = await Promise.all(responsePromises);

    return NextResponse.json({ boardResponses });
  } catch (error: any) {
    return NextResponse.json({ error: error.message }, { status: 500 });
  }
}
